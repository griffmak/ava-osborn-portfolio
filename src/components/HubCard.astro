---
interface Props {
  title: string;
  href: string;
  imageUrl?: string;
  /** 'cover' fills the card with the image (campaign photos);
   *  'contain' centers a logo on a light bg with the title in a bottom strip. */
  imageMode?: 'cover' | 'contain';
  /** When true, opens the link in a new tab (used for external Azul glossary links). */
  external?: boolean;
}

const { title, href, imageUrl, imageMode = 'cover', external = false } = Astro.props;
const hasImage = Boolean(imageUrl);
const target = external ? '_blank' : undefined;
const rel = external ? 'noopener noreferrer' : undefined;
const ariaLabel = external ? `${title} (opens in new tab)` : title;
---

<a
  href={href}
  target={target}
  rel={rel}
  aria-label={ariaLabel}
  class:list={[
    'group relative block overflow-hidden rounded-[4px] border transition-all duration-150 ease-in-out hover:scale-[1.02]',
    hasImage
      ? 'border-border hover:border-border-hover'
      : 'border-border-hover',
  ]}
  style="aspect-ratio: 4/3;"
>
  {hasImage && imageMode === 'cover' && (
    <>
      <img
        src={imageUrl}
        alt=""
        aria-hidden="true"
        class="absolute inset-0 h-full w-full object-cover object-center"
      />
      <div
        class="absolute inset-0"
        style="background: linear-gradient(to top, rgba(20,6,1,0.85) 0%, rgba(20,6,1,0.45) 40%, rgba(20,6,1,0.05) 70%, transparent 100%);"
        aria-hidden="true"
      />
      <p class="absolute bottom-4 left-4 right-4 z-10 font-heading italic text-xl text-text leading-snug md:text-2xl">
        {title}
      </p>
    </>
  )}

  {hasImage && imageMode === 'contain' && (
    <>
      <div class="absolute inset-0 flex items-center justify-center bg-text px-10 pb-12 pt-6">
        <img
          src={imageUrl}
          alt=""
          aria-hidden="true"
          class="max-h-full max-w-full object-contain"
        />
      </div>
      <div
        class="absolute bottom-0 left-0 right-0 bg-surface px-4 py-3"
        aria-hidden="true"
      >
        <p class="font-heading italic text-center text-lg text-text md:text-xl">
          {title}
        </p>
      </div>
    </>
  )}

  {!hasImage && (
    <div class="absolute inset-0 flex items-center justify-center bg-surface px-6">
      <p class="font-heading italic text-center text-2xl text-text md:text-3xl">
        {title}
      </p>
    </div>
  )}
</a>
