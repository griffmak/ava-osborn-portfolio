---
interface Props {
  imageUrl: string;
  postUrl: string;
  altText: string;
}

const { imageUrl, postUrl, altText } = Astro.props;
const hasLink = postUrl.length > 0;
---

{hasLink ? (
  <a
    href={postUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="phone-frame"
    aria-label={`View post: ${altText}`}
  >
    <div class="phone-screen">
      <img src={imageUrl} alt={altText} class="phone-image" />
      <div class="phone-reflection" aria-hidden="true"></div>
    </div>
  </a>
) : (
  <div class="phone-frame phone-frame--static">
    <div class="phone-screen">
      <img src={imageUrl} alt={altText} class="phone-image" />
      <div class="phone-reflection" aria-hidden="true"></div>
    </div>
  </div>
)}

<style>
  /* iPhone-native 9:19.5 aspect ratio so the 1290×2796 source screenshots
     fill the frame exactly with no white space or cropping. */
  .phone-frame {
    display: block;
    width: 260px;
    height: 563px;
    border-radius: 42px;
    border: 4px solid var(--color-border);
    background: #1a0b04;
    box-shadow: 0 18px 60px rgba(0, 0, 0, 0.65);
    position: relative;
    flex-shrink: 0;
    transition: transform 150ms ease, box-shadow 150ms ease, border-color 150ms ease;
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .phone-frame {
      width: 220px;
      height: 477px;
      border-radius: 36px;
    }
  }

  .phone-frame:not(.phone-frame--static):hover {
    transform: scale(1.03);
    box-shadow: 0 16px 50px rgba(0, 0, 0, 0.75);
    border-color: var(--color-border-hover);
  }

  .phone-frame:not(.phone-frame--static):focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 3px;
  }

  /* No faux notch — the source iPhone screenshots already include the real
     iOS status bar (time, signal, wifi, battery). */
  .phone-screen {
    position: absolute;
    inset: 5px;
    border-radius: 36px;
    overflow: hidden;
  }

  .phone-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .phone-reflection {
    position: absolute;
    inset: 0;
    border-radius: 36px;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.06) 0%, transparent 50%);
    pointer-events: none;
    z-index: 1;
  }
</style>
