---
interface Props {
  imageUrl: string;
  postUrl: string;
  altText: string;
}

const { imageUrl, postUrl, altText } = Astro.props;
const hasLink = postUrl.length > 0;
---

{hasLink ? (
  <a
    href={postUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="phone-frame"
    aria-label={`View post: ${altText}`}
  >
    <div class="phone-screen">
      <div class="phone-notch" aria-hidden="true"></div>
      <img src={imageUrl} alt={altText} class="phone-image" />
      <div class="phone-reflection" aria-hidden="true"></div>
    </div>
  </a>
) : (
  <div class="phone-frame phone-frame--static">
    <div class="phone-screen">
      <div class="phone-notch" aria-hidden="true"></div>
      <img src={imageUrl} alt={altText} class="phone-image" />
      <div class="phone-reflection" aria-hidden="true"></div>
    </div>
  </div>
)}

<style>
  .phone-frame {
    display: block;
    width: 160px;
    height: 320px;
    border-radius: 26px;
    border: 3px solid var(--color-border);
    background: #1a0b04;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.6);
    position: relative;
    flex-shrink: 0;
    transition: transform 150ms ease, box-shadow 150ms ease, border-color 150ms ease;
    text-decoration: none;
  }

  .phone-frame:not(.phone-frame--static):hover {
    transform: scale(1.03);
    box-shadow: 0 16px 50px rgba(0, 0, 0, 0.75);
    border-color: var(--color-border-hover);
  }

  .phone-frame:not(.phone-frame--static):focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 3px;
  }

  .phone-screen {
    position: absolute;
    inset: 4px;
    border-radius: 22px;
    overflow: hidden;
  }

  .phone-notch {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 14px;
    border-radius: 7px;
    background: #1a0b04;
    z-index: 2;
  }

  .phone-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .phone-reflection {
    position: absolute;
    inset: 0;
    border-radius: 22px;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.06) 0%, transparent 50%);
    pointer-events: none;
    z-index: 1;
  }
</style>
