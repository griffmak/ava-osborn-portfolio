---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import HubCard from '../components/HubCard.astro';
import headshot from '../assets/headshot.jpg';

const buttonImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/buttons/*.{jpg,jpeg,png,webp}',
  { eager: true },
);

function buttonSrc(filename: string): string {
  const entry = buttonImages[`../assets/buttons/${filename}`];
  if (!entry) throw new Error(`Hub: no button image found for "${filename}"`);
  return entry.default.src;
}

// Ava-authored bio (2026-05-25). Two paragraphs rendered separately.
const bioParagraphs = [
  "I architect data-informed strategies and use cultural intuition to bring them to life for impactful marketing initiatives. I'm a graduate from the University of Michigan, where I studied Economics and Business Administration and built a foundation in the analytical and strategic thinking that shapes how I work as a marketer.",
  "I work on the Social Marketing and Content Strategy team at Ralph Lauren, where I have contributed to high-impact campaigns across brand moments, fashion weeks, sports partnerships, and everyday seasonal content. My approach is data-driven and people-first. I believe marketing is about understanding people, what moves them and why. This is my foundation for creating impactful moments that resonate with the right people.",
];
---

<Base
  title="Ava Osborn — Social Marketing Strategist"
  description="Ava Osborn is a social marketing and content strategist at Ralph Lauren, building campaigns that drive cultural moments at scale."
>
  <!-- Hero -->
  <section aria-label="Introduction" class="px-6 py-20 md:py-32">
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-12 md:items-start">

        <!-- Headshot (5/12) -->
        <div class="md:col-span-5">
          <Image
            src={headshot}
            alt="Ava Osborn — Social Marketing and Content Strategist"
            class="w-full object-cover"
            style="aspect-ratio: 4/5;"
            widths={[480, 960]}
            sizes="(max-width: 768px) 100vw, 41vw"
          />
        </div>

        <!-- Bio (7/12) -->
        <div class="md:col-span-7 flex flex-col justify-center">
          <h1
            class="font-heading text-6xl text-text leading-[0.9] md:text-8xl"
            style="font-weight: 400; letter-spacing: -0.02em;"
          >
            Ava Osborn
          </h1>

          <div class="font-body mt-6 space-y-5 text-base text-muted leading-[1.7] md:text-lg">
            {bioParagraphs.map((para) => <p>{para}</p>)}
          </div>

          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="/resume.pdf"
              download="Ava Osborn Resume.pdf"
              class="font-body inline-block border border-border px-6 py-3 text-sm font-semibold text-text transition-all duration-150 ease-in-out hover:bg-surface-hover hover:border-border-hover"
              style="letter-spacing: 0.08em;"
            >
              Download Resume
            </a>
            <a
              href="https://linkedin.com/in/ava-osborn/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn profile (opens in new tab)"
              class="font-body inline-block border border-border px-6 py-3 text-sm font-semibold text-text transition-all duration-150 ease-in-out hover:bg-surface-hover hover:border-border-hover"
              style="letter-spacing: 0.08em;"
            >
              LinkedIn
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Hub -->
  <section aria-label="Work and writing" class="px-6 pb-24 md:pb-32">
    <div class="mx-auto max-w-6xl">

      <h2
        class="mb-8 font-heading text-4xl font-normal text-text md:mb-10 md:text-5xl"
        style="letter-spacing: -0.01em;"
      >
        Projects
      </h2>

      <!-- Row 1: 3 campaign cards (col-span-2 each in a 6-col grid) -->
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-6">
        <div class="sm:col-span-2">
          <HubCard
            title="Oak Bluffs 2025"
            href="/work/oak-bluffs"
            imageUrl={buttonSrc('oak-bluffs-button.jpg')}
            objectPosition="center 25%"
          />
        </div>
        <div class="sm:col-span-2">
          <HubCard
            title="Paris Fashion Week"
            href="/work/paris-fashion-week"
            imageUrl={buttonSrc('paris-fashion-week-button.jpg')}
          />
        </div>
        <div class="sm:col-span-2">
          <HubCard
            title="Ryder Cup"
            href="/work/ryder-cup"
            imageUrl={buttonSrc('ryder-cup-button.jpg')}
          />
        </div>

        <!-- Row 2: 2 wider cards (col-span-3 each) -->
        <div class="sm:col-span-3">
          <HubCard
            title="Australian Open"
            href="/work/australian-open"
            imageUrl={buttonSrc('australian-open-button.jpg')}
            objectPosition="center 25%"
          />
        </div>
        <div class="sm:col-span-3">
          <HubCard
            title="Glossary Definitions"
            href="/glossary"
            imageUrl={buttonSrc('azul-button.png')}
            imageMode="contain"
          />
        </div>
      </div>

    </div>
  </section>
</Base>
