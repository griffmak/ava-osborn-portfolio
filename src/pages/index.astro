---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import HubCard from '../components/HubCard.astro';
import headshot from '../assets/headshot.jpg';

const caseStudyImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/case-studies/*.{jpg,jpeg,png,webp}',
  { eager: true },
);

function imgSrc(filename: string): string {
  const entry = caseStudyImages[`../assets/case-studies/${filename}`];
  if (!entry) throw new Error(`Hub: no case-study image found for "${filename}"`);
  return entry.default.src;
}

// PLACEHOLDER — Ava to replace with her own words before launch.
// Source: Ava/portfolio-v2-content/bio.txt
const bio =
  "I believe the best social strategy doesn’t live in a content calendar — it lives at the intersection of culture and data. At Ralph Lauren, I’ve led activations across Paris Fashion Week, the Ryder Cup, and the Australian Open, earning the brand’s highest-ever post performance and a #1 competitive ranking across eight platforms during PFW. I approach every campaign as an opportunity to put a brand inside a moment that actually matters — and I treat every number that comes back as a signal worth acting on.";
---

<Base
  title="Ava Osborn — Social Marketing Strategist"
  description="Ava Osborn is a social marketing and content strategist at Ralph Lauren, building campaigns that drive cultural moments at scale."
>
  <!-- Hero -->
  <section aria-label="Introduction" class="px-6 py-20 md:py-32">
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-12 md:items-start">

        <!-- Headshot (5/12) -->
        <div class="md:col-span-5">
          <Image
            src={headshot}
            alt="Ava Osborn — Social Marketing and Content Strategist"
            class="w-full object-cover"
            style="aspect-ratio: 4/5;"
            widths={[480, 960]}
            sizes="(max-width: 768px) 100vw, 41vw"
          />
        </div>

        <!-- Bio (7/12) -->
        <div class="md:col-span-7 flex flex-col justify-center">
          <h1
            class="font-heading text-6xl text-text leading-[0.9] md:text-8xl"
            style="font-weight: 400; letter-spacing: -0.02em;"
          >
            Ava Osborn
          </h1>

          <p class="font-body mt-6 text-base text-muted leading-[1.7] md:text-lg">
            {bio}
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="/resume.pdf"
              download
              class="font-body inline-block border border-border px-6 py-3 text-sm font-semibold text-text transition-all duration-150 ease-in-out hover:bg-surface-hover hover:border-border-hover"
              style="letter-spacing: 0.08em;"
            >
              Download Resume
            </a>
            <a
              href="https://linkedin.com/in/ava-osborn/"
              target="_blank"
              rel="noopener noreferrer"
              class="font-body inline-block border border-border px-6 py-3 text-sm font-semibold text-text transition-all duration-150 ease-in-out hover:bg-surface-hover hover:border-border-hover"
              style="letter-spacing: 0.08em;"
            >
              LinkedIn
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Hub -->
  <section aria-label="Work and writing" class="px-6 pb-24 md:pb-32">
    <div class="mx-auto max-w-6xl">

      <!-- Row 1: 3 campaign cards (col-span-2 each in a 6-col grid) -->
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-6">
        <div class="sm:col-span-2">
          <HubCard
            title="Oak Bluffs 2025"
            href="/work/oak-bluffs"
            imageUrl={imgSrc('oak-bluffs.jpg')}
          />
        </div>
        <div class="sm:col-span-2">
          <HubCard
            title="Paris Fashion Week"
            href="/work/paris-fashion-week"
            imageUrl={imgSrc('paris-fw.jpg')}
          />
        </div>
        <div class="sm:col-span-2">
          <HubCard
            title="Ryder Cup"
            href="/work/ryder-cup"
            imageUrl={imgSrc('ryder-cup.jpg')}
          />
        </div>

        <!-- Row 2: 2 wider cards (col-span-3 each) -->
        <div class="sm:col-span-3">
          <HubCard
            title="Australian Open"
            href="/work/australian-open"
            imageUrl={imgSrc('australian-open.jpg')}
          />
        </div>
        <div class="sm:col-span-3">
          <HubCard
            title="Glossary Definitions"
            href="/glossary"
          />
        </div>
      </div>

    </div>
  </section>
</Base>
