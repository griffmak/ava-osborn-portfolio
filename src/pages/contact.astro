---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contact"
  description="Get in touch with Ava Osborn — Social Marketing and Content Strategist open to new opportunities in social media and content marketing."
>
  <section class="flex min-h-[70vh] items-center px-6 py-24 md:py-32">
    <div class="mx-auto w-full max-w-xl">
      <p class="mb-6 font-body text-sm font-medium uppercase tracking-widest text-muted">Get In Touch</p>
      <h1 class="mb-8 font-heading text-5xl font-normal tracking-tight text-text md:text-7xl">
        Let's Connect
      </h1>
      <p class="mb-12 font-body text-base leading-relaxed text-muted">
        The best way to reach me is by email or LinkedIn.
      </p>

      <div class="space-y-6">
        <div>
          <p class="mb-2 font-body text-sm font-medium uppercase tracking-widest text-muted">Email</p>
          <a
            href="mailto:ava.osborn1@gmail.com"
            class="font-body text-2xl font-medium text-text transition-opacity duration-200 hover:opacity-60 md:text-3xl"
          >
            ava.osborn1@gmail.com
          </a>
        </div>

        <div>
          <p class="mb-2 font-body text-sm font-medium uppercase tracking-widest text-muted">LinkedIn</p>
          <a
            href="https://www.linkedin.com/in/ava-osborn/"
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-2xl font-medium text-text transition-opacity duration-200 hover:opacity-60 md:text-3xl"
          >
            linkedin.com/in/ava-osborn
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
