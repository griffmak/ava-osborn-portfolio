---
import type { ImageMetadata } from 'astro';
import type { CaseStudy } from '../../data/work';
import { caseStudies } from '../../data/work';
import PhoneMockup from '../../components/PhoneMockup.astro';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  return caseStudies.map((cs) => ({
    params: { slug: cs.slug },
    props: { caseStudy: cs },
  }));
}

interface Props {
  caseStudy: CaseStudy;
}

const { caseStudy } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/case-studies/*.{jpg,jpeg,png,webp}',
  { eager: true },
);

const resolvedPostImages = caseStudy.postImages.flatMap((filename) => {
  const mod = images[`../../assets/case-studies/${filename}`];
  if (!mod) {
    console.warn(`[slug].astro: no image found for "${filename}" in ${caseStudy.slug} — skipping`);
    return [];
  }
  return [mod.default.src];
});

// Hypothesis A title split: italicize the trailing 4-digit year if present,
// otherwise italicize the last word ("Australian Open" → "Australian *Open*").
const titleSplit = (() => {
  const yearMatch = caseStudy.title.match(/^(.+?)\s+(\d{4})$/);
  if (yearMatch) return { head: yearMatch[1], tail: yearMatch[2] };
  const lastSpace = caseStudy.title.lastIndexOf(' ');
  if (lastSpace > 0) {
    return {
      head: caseStudy.title.slice(0, lastSpace),
      tail: caseStudy.title.slice(lastSpace + 1),
    };
  }
  return { head: caseStudy.title, tail: '' };
})();
---

<Base title={caseStudy.title} description={caseStudy.summary}>
  <article>
    <!-- Back link -->
    <div class="mx-auto max-w-4xl px-6 pt-8">
      <a
        href="/"
        class="text-sm text-muted transition-colors duration-150 hover:text-text"
      >
        ← Work
      </a>
    </div>

    <!--
      Two title treatment hypotheses for Ava to compare. Variant A is the
      default. Append #b to the URL to preview Variant B (watermark year).
      Once we pick a winner, delete the loser + the small variant labels.
    -->

    <!-- Variant A: Editorial accent (thin rules + italic word + italic role) -->
    <section class="variant variant-a relative mt-6 w-full bg-surface py-16 md:py-20">
      <p
        class="absolute left-4 top-4 text-[10px] font-semibold uppercase text-muted opacity-50"
        style="letter-spacing: 0.18em;"
      >
        Variant A
      </p>
      <div class="mx-auto max-w-4xl px-6 text-center">
        <div class="mx-auto mb-7 h-px w-12 bg-muted opacity-40" aria-hidden="true"></div>

        <p
          class="text-xs font-semibold uppercase text-muted"
          style="letter-spacing: 0.24em;"
        >
          {caseStudy.brand}
        </p>

        <h1
          class="mt-5 font-heading text-5xl font-normal text-text md:text-7xl"
          style="letter-spacing: -0.02em; line-height: 1.0;"
        >
          {titleSplit.head}
          {titleSplit.tail && (
            <em style="font-style: italic;">&nbsp;{titleSplit.tail}</em>
          )}
        </h1>

        <p
          class="mt-5 text-sm italic text-muted"
          style="letter-spacing: 0.04em;"
        >
          {caseStudy.role} · {caseStudy.year}
        </p>
      </div>
    </section>

    <!-- Variant B: Watermark year backdrop (hidden by default; #b in URL shows it) -->
    <section class="variant variant-b relative mt-6 w-full bg-surface py-16 md:py-20 overflow-hidden">
      <p
        class="absolute left-4 top-4 z-20 text-[10px] font-semibold uppercase text-muted opacity-50"
        style="letter-spacing: 0.18em;"
      >
        Variant B
      </p>
      <div class="pointer-events-none absolute inset-0 flex items-center justify-center" aria-hidden="true">
        <span
          class="font-heading italic leading-none text-text"
          style="font-size: 22rem; opacity: 0.06; letter-spacing: -0.05em;"
        >
          {caseStudy.year}
        </span>
      </div>
      <div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
        <p
          class="text-sm font-medium uppercase text-muted"
          style="letter-spacing: 0.14em;"
        >
          {caseStudy.brand} · {caseStudy.role}
        </p>

        <h1
          class="mt-4 font-heading text-5xl font-normal text-text md:text-7xl"
          style="letter-spacing: -0.02em; line-height: 1.05;"
        >
          {caseStudy.title}
        </h1>
      </div>
    </section>

    <!-- Brief description -->
    <div class="mx-auto max-w-2xl px-6 py-8">
      <p class="text-base leading-relaxed text-text md:text-lg">
        {
          caseStudy.description !== null
            ? caseStudy.description
            : 'Campaign description coming soon.'
        }
      </p>
    </div>

    <!-- Phone mockups row (wraps to multiple rows for 4-phone campaigns) -->
    {
      resolvedPostImages.length > 0 && (
        <div class="px-6 py-12">
          <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-4 md:gap-6">
            {resolvedPostImages.map((src, i) => (
              <PhoneMockup
                imageUrl={src}
                postUrl={caseStudy.postUrls[i] ?? ''}
                altText={`${caseStudy.title} post ${i + 1}`}
              />
            ))}
          </div>
        </div>
      )
    }

    <div class="pb-24"></div>
  </article>

  <!--
    Variant toggle: by default show A. If URL hash is #b, show B instead.
    Once Ava picks a winner, delete both variants except the chosen one.
  -->
  <style>
    .variant-b { display: none; }
    :global(html.show-b) .variant-a { display: none; }
    :global(html.show-b) .variant-b { display: block; }
  </style>
  <script is:inline>
    (function () {
      const apply = () => {
        document.documentElement.classList.toggle('show-b', location.hash === '#b');
      };
      apply();
      window.addEventListener('hashchange', apply);
    })();
  </script>
</Base>
