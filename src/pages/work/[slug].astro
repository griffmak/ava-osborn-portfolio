---
import type { ImageMetadata } from 'astro';
import type { CaseStudy } from '../../data/work';
import { caseStudies } from '../../data/work';
import PhoneMockup from '../../components/PhoneMockup.astro';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  return caseStudies.map((cs) => ({
    params: { slug: cs.slug },
    props: { caseStudy: cs },
  }));
}

interface Props {
  caseStudy: CaseStudy;
}

const { caseStudy } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/case-studies/*.{jpg,jpeg,png,webp}',
  { eager: true },
);

const resolvedPostImages = caseStudy.postImages.flatMap((filename) => {
  const mod = images[`../../assets/case-studies/${filename}`];
  if (!mod) {
    console.warn(`[slug].astro: no image found for "${filename}" in ${caseStudy.slug} — skipping`);
    return [];
  }
  return [mod.default.src];
});
---

<Base title={caseStudy.title} description={caseStudy.summary}>
  <article>
    <!-- Campaign header -->
    <div class="mx-auto max-w-4xl px-6 pt-16 pb-8">
      <a
        href="/"
        class="text-sm text-muted transition-colors duration-150 hover:text-text"
      >
        ← Work
      </a>

      <p
        class="mt-4 text-sm font-medium text-muted"
        style="letter-spacing: 0.06em;"
      >
        {caseStudy.brand} · {caseStudy.year} · {caseStudy.role}
      </p>

      <h1
        class="mt-2 font-heading text-4xl font-normal text-text md:text-5xl"
        style="letter-spacing: -0.01em; line-height: 1.1;"
      >
        {caseStudy.title}
      </h1>
    </div>

    <!-- Brief description -->
    <div class="mx-auto max-w-2xl px-6 py-8">
      <p class="text-base leading-relaxed text-text md:text-lg">
        {
          caseStudy.description !== null
            ? caseStudy.description
            : 'Campaign description coming soon.'
        }
      </p>
    </div>

    <!-- Phone mockups row (only rendered if postImages populated) -->
    {
      resolvedPostImages.length > 0 && (
        <div class="px-6 py-12">
          <div class="flex flex-col items-center gap-8 md:flex-row md:justify-center">
            {resolvedPostImages.map((src, i) => (
              <PhoneMockup
                imageUrl={src}
                postUrl={caseStudy.postUrls[i] ?? ''}
                altText={`${caseStudy.title} post ${i + 1}`}
              />
            ))}
          </div>
        </div>
      )
    }

    <!-- Metrics panel -->
    <div class="w-full bg-surface py-16">
      <p
        class="mb-10 text-center text-xs font-semibold uppercase text-muted"
        style="letter-spacing: 0.15em;"
      >
        The Numbers
      </p>
      <div class="flex items-center justify-center gap-16">
        {
          caseStudy.metrics.map((metric, i) => (
            <>
              {i > 0 && (
                <div
                  class="hidden h-12 w-px bg-border md:block"
                  aria-hidden="true"
                />
              )}
              <div class="text-center">
                <p
                  class="font-heading text-5xl font-normal text-text md:text-6xl"
                  style="letter-spacing: -0.02em; line-height: 1;"
                >
                  {metric.value}
                </p>
                <p
                  class="mt-2 text-xs font-medium uppercase text-muted"
                  style="letter-spacing: 0.08em;"
                >
                  {metric.unit}
                </p>
              </div>
            </>
          ))
        }
      </div>
    </div>
  </article>
</Base>
